func untag_pod(v0, v1) -> Variant:
	if object.property_exists(v1, "loading"):
		if PogRuntime.TRACE:
			debug.print_string("iJafsScript.TagPod: Cannot untag pod, as it is being loaded. \n")
		ihud.pog_print("hud_tag_error_pod_is_loading")
		ihud.play_audio_cue(1)
	group.remove_sim(v0, v1)
	isim.set_mission_critical(v1, 0)
	sim.set_cullable(v1, 1)
	await enable_pod_dockport(v1)
	ihud.pog_print("hud_pod_untagged")
	ihud.play_audio_cue(0)
	if PogRuntime.TRACE:
