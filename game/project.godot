; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="IW2 Remaster"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.7")

; Flight and command keys are NOT InputMap actions -- they are a central
; keycode table in game/scripts/main_state.gd (BIND_*), polled/matched in
; main_flight and main.gd. Edit the bindings there.
